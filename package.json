{
  "name": "solverforge",
  "version": "0.2.1",
  "private": true,
  "description": "Version management for SolverForge",
  "scripts": {
    "release": "commit-and-tag-version",
    "release:patch": "commit-and-tag-version --release-as patch",
    "release:minor": "commit-and-tag-version --release-as minor",
    "release:major": "commit-and-tag-version --release-as major",
    "release:dry": "commit-and-tag-version --dry-run"
  },
  "devDependencies": {
    "commit-and-tag-version": "^12.5.0"
  },
  "commit-and-tag-version": {
    "bumpFiles": [
      {"filename": "package.json", "type": "json"},
      {"filename": "Cargo.toml", "updater": "scripts/cargo-version.js"},
      {"filename": "solverforge-python/pyproject.toml", "updater": "scripts/pyproject-version.js"},
      {"filename": "timefold-wasm-service/pom.xml", "updater": "scripts/pom-version.js"}
    ],
    "tagPrefix": "v",
    "header": "# Changelog\n\nAll notable changes to SolverForge will be documented in this file.\n",
    "types": [
      {"type": "feat", "section": "Features"},
      {"type": "fix", "section": "Bug Fixes"},
      {"type": "perf", "section": "Performance"},
      {"type": "refactor", "section": "Refactoring"},
      {"type": "docs", "section": "Documentation"},
      {"type": "chore", "section": "Maintenance"},
      {"type": "ci", "section": "CI/CD"},
      {"type": "test", "section": "Tests"}
    ]
  }
}
